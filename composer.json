{
    "name": "billabear/php-sdk",
    "description": "The offical PHP SDK for BillaBear",
    "type": "library",
    "license": "GPL-3.0-or-later",
    "autoload": {
        "psr-4": {
            "Billabear\\PhpSdk\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Iain",
            "email": "iain@humblyarrogant.io"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "nyholm/psr7": "^1.5",
        "php-http/guzzle7-adapter": "^1.0",
        "friendsofphp/php-cs-fixer": "^3.11"
    },
    "require": {
        "php": "^8.1",
        "psr/http-message": "^1.0",
        "php-http/discovery": "^1.14",
        "psr/http-client": "^1.0",
        "php-http/client-common": "^2.5"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
